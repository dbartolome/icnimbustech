# SGS España — Inteligencia Comercial
# Copia: cp .env.hostinger.example .env.hostinger
# NUNCA subas .env.hostinger a git.

# PostgreSQL
POSTGRES_USER=sgs_user
POSTGRES_PASSWORD=<CAMBIAR: password seguro>
POSTGRES_DB=sgs_prod

# MinIO
MINIO_ACCESS_KEY=sgs_minio
MINIO_SECRET_KEY=<CAMBIAR: password seguro para MinIO>
MINIO_BUCKET=sgs-documentos
MINIO_PUBLIC_URL=http://76.13.9.183:9100
MINIO_PORT=9100
MINIO_CONSOLE_PORT=9101

# Ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2:3b

# IA externa
IA_RESEARCH_PROVIDER=anthropic
IA_RESEARCH_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=<CAMBIAR: sk-ant-...>
OPENAI_API_KEY=
GEMINI_API_KEY=

# JWT — genera con: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=<CAMBIAR: cadena >= 64 chars>
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Puertos
BACKEND_PORT=8033
FRONTEND_PORT=3033

# URLs públicas — sustituye 76.13.9.183 por la IP del VPS
NEXT_PUBLIC_API_URL=http://76.13.9.183:8033
NEXT_PUBLIC_OLLAMA_URL=

# CORS
ALLOWED_ORIGINS=["http://76.13.9.183:3033","http://localhost:3033"]

# App
LOG_LEVEL=INFO
