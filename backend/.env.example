# =============================================================================
# SGS España — Backend — Variables de entorno
# Copiar a .env y rellenar con valores reales
# NUNCA commitear el .env real
# =============================================================================

# ── Entorno ────────────────────────────────────────────────────────────────────
ENVIRONMENT=production          # development | production

# ── Base de datos ──────────────────────────────────────────────────────────────
# Railway: copiar de Railway → tu proyecto → PostgreSQL → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# ── Redis ──────────────────────────────────────────────────────────────────────
# Railway: copiar de Railway → tu proyecto → Redis → Connection string
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ── Autenticación JWT ──────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REEMPLAZAR_CON_CLAVE_ALEATORIA_64_BYTES
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── IA externa (research / deep research) ─────────────────────────────────────
# Selecciona proveedor externo para investigación web
IA_RESEARCH_PROVIDER=anthropic   # anthropic | openai | gemini | ollama
IA_RESEARCH_MODEL=claude-sonnet-4-20250514
IA_RESEARCH_MODEL_ANTHROPIC=claude-sonnet-4-20250514
IA_RESEARCH_MODEL_OPENAI=gpt-4.1
IA_RESEARCH_MODEL_GEMINI=gemini-2.5-pro

# Claves API por proveedor externo (rellena solo las que uses)
ANTHROPIC_API_KEY=sk-ant-REEMPLAZAR
OPENAI_API_KEY=sk-REEMPLAZAR
GEMINI_API_KEY=REEMPLAZAR

# ── IA local/privada (operación: copilot, informes, decks, coaching, etc.) ───
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL_DEFAULT=qwen2.5:14b

# ── CORS ───────────────────────────────────────────────────────────────────────
# URL de tu frontend en Vercel (sin barra final)
ALLOWED_ORIGINS=https://tu-proyecto.vercel.app,http://localhost:3000

# ── Almacenamiento (Supabase Storage) ──────────────────────────────────────────
# Solo necesario para migrar uploads/ locales a la nube
# https://supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=REEMPLAZAR
SUPABASE_BUCKET=sgs-documentos
